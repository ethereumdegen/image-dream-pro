    {
      "id": "fal-ai/flux/schnell",
      "name": "FLUX.1 [schnell]",
      "description": "Fast, high quality text-to-image. Great default for quick iteration.",
      "category": "text-to-image",
      "inputMedia": [],
      "outputMedia": ["image"],
      "outputField": "images",
      "inputs": [
        { "name": "prompt", "label": "Prompt", "type": "textarea", "required": true, "placeholder": "A cinematic photo of..." },
        {
          "name": "image_size",
          "label": "Image size",
          "type": "select",
          "default": "landscape_4_3",
          "options": [
            "square_hd",
            "square",
            "portrait_4_3",
            "portrait_16_9",
            "landscape_4_3",
            "landscape_16_9"
          ]
        },
        { "name": "num_inference_steps", "label": "Steps", "type": "number", "default": 4, "min": 1, "max": 12 },
        { "name": "num_images", "label": "Number of images", "type": "number", "default": 1, "min": 1, "max": 4 },
        { "name": "seed", "label": "Seed (optional)", "type": "number" },
        { "name": "enable_safety_checker", "label": "Safety checker", "type": "boolean", "default": true }
      ]
    },
